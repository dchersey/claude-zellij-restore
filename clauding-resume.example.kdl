// generated by clauding-snapshot — launch with: zellij --layout <thisfile>
//
// EXAMPLE FILE. The session ids and paths below are placeholders. You produce a
// real one by running `clauding-snapshot` inside your live Zellij session; it
// captures the actual running command in each pane (claude-resume execs into
// `claude`, so the live command shows as `claude`) and rewrites it back to a
// resume-by-id pane. A real capture also passes through whatever swap layouts
// and exact geometry your session had, verbatim. This trimmed sample mirrors
// the generic clauding.kdl. Note the resumed panes have no `start_suspended`,
// so they relaunch immediately on restore (run with --suspend to keep them off).

layout {
    cwd "/Users/you/projects"
    tab name="project-a" hide_floating_panes=true {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        pane split_direction="vertical" {
            pane size="35%" stacked=true {
                pane command="npm" cwd="/Users/you/projects/project-a" {
                    args "run" "dev"
                }
                pane command="/Users/you/bin/claude-resume" cwd="/Users/you/projects/project-a/backend" expanded=true {
                    args "--id" "0a1b2c3d-4e5f-6a7b-8c9d-1a2b3c4d5e6f"
                }
            }
            pane command="lazygit" cwd="/Users/you/projects/project-a" size="30%"
            pane cwd="/Users/you/projects/project-a" size="35%"
        }
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="project-b" focus=true hide_floating_panes=true {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        pane split_direction="vertical" {
            pane size="60%" stacked=true {
                pane command="/Users/you/bin/claude-resume" cwd="/Users/you/projects/project-b/backend" expanded=true {
                    args "--id" "1b2c3d4e-5f6a-7b8c-9d0e-2b3c4d5e6f70"
                }
                pane command="/Users/you/bin/claude-resume" cwd="/Users/you/projects/project-b/backend" {
                    args "--id" "2c3d4e5f-6a7b-8c9d-0e1f-3c4d5e6f7081"
                }
            }
            pane command="lazygit" cwd="/Users/you/projects/project-b" size="40%"
        }
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    new_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        pane cwd="/Users/you/projects"
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
}
