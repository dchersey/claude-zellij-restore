#!/usr/bin/env bash
# claude-resume — resume a Claude Code session for a directory, with your
# standard launch line (LSP + skip-permissions) applied in one place.
#
#   claude-resume              pick a session for $PWD (auto if only one)
#   claude-resume --latest     resume the most-recently-active session, no picker
#   claude-resume --pick       always show the picker
#   claude-resume --id <ID>    resume one exact session id (used by generated layouts)
#   claude-resume --list       print the candidate table and exit
#   claude-resume --dir <DIR>  operate on DIR instead of $PWD
#
# Sessions are read from ~/.claude/projects/<encoded-cwd>/<id>.jsonl
# (honors $CLAUDE_CONFIG_DIR). Picker is keyed by git branch + last activity
# + first prompt. No renaming needed; works after a crash.
set -eu

# --- your launch line, in one place --------------------------------------
: "${CLAUDE_BIN:=claude}"
CLAUDE_ENV=( ENABLE_LSP_TOOL=1 )                 # singular; the real flag
CLAUDE_FLAGS=( --dangerously-skip-permissions )  # your standard flags
# -------------------------------------------------------------------------

cfg="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"; proj="$cfg/projects"
mode="auto"; target="$PWD"; want_id=""
while [ $# -gt 0 ]; do case "$1" in
  --latest) mode="latest";;
  --pick)   mode="pick";;
  --list)   mode="list";;
  --id)     shift; want_id="$1"; mode="id";;
  --dir)    shift; target="$1";;
  *) echo "claude-resume: unknown arg: $1" >&2; exit 2;;
esac; shift; done

encode_cwd() { printf '%s' "$1" | sed 's/[^A-Za-z0-9]/-/g'; }
mtime() { stat -c %Y "$1" 2>/dev/null || stat -f %m "$1"; }
fmt()   { date -d "@$1" '+%Y-%m-%d %H:%M' 2>/dev/null || date -r "$1" '+%Y-%m-%d %H:%M'; }

# resume an exact id: find its transcript, cd to the recorded cwd, exec.
launch_id() {
  local id="$1" file rec
  file="$(find "$proj" -name "$id.jsonl" 2>/dev/null | head -1)"
  if [ -z "$file" ]; then echo "claude-resume: session $id not found" >&2; exit 1; fi
  rec="$(jq -r 'select(.cwd!=null)|.cwd' "$file" 2>/dev/null | head -1)"
  [ -n "$rec" ] && [ -d "$rec" ] && cd "$rec"
  if [ -n "${CLAUDE_RESUME_DRYRUN:-}" ]; then
    echo "[dryrun] (cd $(pwd)) env ${CLAUDE_ENV[*]} $CLAUDE_BIN ${CLAUDE_FLAGS[*]} --resume $id"; exit 0
  fi
  exec env "${CLAUDE_ENV[@]}" "$CLAUDE_BIN" "${CLAUDE_FLAGS[@]}" --resume "$id"
}

[ "$mode" = "id" ] && launch_id "$want_id"

[ -d "$proj" ] || { echo "no $proj — starting fresh" >&2; exec env "${CLAUDE_ENV[@]}" "$CLAUDE_BIN" "${CLAUDE_FLAGS[@]}"; }

collect_files() {
  local enc dir; enc="$(encode_cwd "$target")"; dir="$proj/$enc"
  shopt -s nullglob; local f=( "$dir"/*.jsonl "$dir"/sessions/*.jsonl ); shopt -u nullglob
  if [ ${#f[@]} -gt 0 ]; then printf '%s\n' "${f[@]}"; return; fi
  grep -rl --include='*.jsonl' -m1 "\"cwd\":\"$target\"" "$proj" 2>/dev/null || true
}
files=()
while IFS= read -r _f; do [ -n "$_f" ] && files+=("$_f"); done < <(collect_files)
[ ${#files[@]} -gt 0 ] || { echo "no sessions for $target — starting fresh" >&2; exec env "${CLAUDE_ENV[@]}" "$CLAUDE_BIN" "${CLAUDE_FLAGS[@]}"; }

rows=""
for f in "${files[@]}"; do
  id="$(basename "$f" .jsonl)"; mt="$(mtime "$f")"
  branch="$(jq -r 'select(.gitBranch!=null)|.gitBranch' "$f" 2>/dev/null | head -1)"; : "${branch:=-}"
  msg="$(jq -r 'select(.type=="user")|.message.content|if type=="string" then . elif type=="array" then ([.[]|select(.type?=="text")|.text]|join(" ")) else "" end' "$f" 2>/dev/null | grep -v '^[[:space:]]*$' | head -1 | tr -s ' ' | cut -c1-72)"; : "${msg:=(no prompt)}"
  rows+="$mt"$'\t'"$(fmt "$mt")"$'\t'"$branch"$'\t'"$msg"$'\t'"$id"$'\n'
done
rows="$(printf '%s' "$rows" | sort -rn -k1,1 | head -25)"
n="$(printf '%s' "$rows" | grep -c . || true)"

if [ "$mode" = "list" ]; then
  printf '%s\n' "$rows" | awk -F'\t' 'NF{printf "%-16s  %-26s  %-72s  %s\n",$2,$3,$4,$5}'; exit 0
fi
if [ "$mode" = "latest" ] || { [ "$mode" = "auto" ] && [ "$n" -eq 1 ]; }; then
  line="$(printf '%s' "$rows" | head -1)"
else
  line="$(printf '%s' "$rows" | fzf --delimiter='\t' --with-nth=2,3,4 \
            --prompt="resume in ${target##*/} > " \
            --header=$'when              branch                      first prompt' \
            --height=45% --reverse)" || exit 0
fi
[ -n "$line" ] || exit 0
launch_id "$(printf '%s' "$line" | awk -F'\t' '{print $5}')"
