#!/usr/bin/env bash
# clauding-snapshot — photograph the current Zellij session into a resume layout.
# Rewrites every live claude pane into a `claude-resume --id <id>` pane, resolving
# each id from the live session registry (~/.claude/sessions/<pid>.json), scoped to
# the current zellij window. Also recovers "stealth" claude panes that zellij
# mislabeled with a claude-spawned child command (e.g. an MCP server / caffeinate).
# Geometry, plugins, floating panes and other command panes pass through
# byte-for-byte (use --run-all to auto-start those instead of leaving them
# suspended). The default swap_tiled/floating_layout blocks are dropped: in a
# *restore* layout they make zellij snap the restored arrangement to a generic
# swap layout the first time you close a pane (auto_layout=true), fragmenting it.
# Keep them with --keep-swap-layouts (or CLAUDING_KEEP_SWAP_LAYOUTS=1).
#
#   clauding-snapshot                 dump current session -> ~/tmp/clauding-restore.kdl
#   clauding-snapshot -o FILE         choose output path
#   clauding-snapshot --from DUMP     rewrite an existing dump file (no zellij call)
#   clauding-snapshot --suspend       keep claude panes start_suspended (Enter to resume each)
#   clauding-snapshot --run-all       also auto-run non-claude command panes (strip start_suspended)
#                                     (or set CLAUDING_RUN_ALL=1 to make it the default)
#   clauding-snapshot --keep-swap-layouts  keep zellij's swap_*_layout blocks (restored layout may
#                                     reflow to a generic swap layout when you close a pane)
#   clauding-snapshot --no-stealth    trust dump-layout; skip the MCP-masking recovery heuristic
#                                     (also via CLAUDING_NO_STEALTH=1, or automatically on a zellij
#                                      release that includes the dump-layout fix — see below)
set -eu
out="$HOME/tmp/clauding-restore.kdl"; src=""; suspend=0; run_all=0
[ -n "${CLAUDING_RUN_ALL:-}" ] && run_all=1
no_stealth=0; [ -n "${CLAUDING_NO_STEALTH:-}" ] && no_stealth=1
keep_swap=0; [ -n "${CLAUDING_KEEP_SWAP_LAYOUTS:-}" ] && keep_swap=1
while [ $# -gt 0 ]; do case "$1" in
  -o) shift; out="$1";;
  --from) shift; src="$1";;
  --suspend) suspend=1;;
  --run-all) run_all=1;;
  --keep-swap-layouts) keep_swap=1;;
  --no-stealth) no_stealth=1;;
  *) echo "clauding-snapshot: unknown arg: $1" >&2; exit 2;;
esac; shift; done

# Stealth recovery works around a zellij bug where `dump-layout` reports a pane's
# child process (e.g. an MCP server) instead of the pane's own command, so a
# `claude` pane can't be recognized. It's a safe superset: when dump-layout is
# correct it finds nothing to recover and is a no-op. Once the fix ships in a
# tagged zellij release, set DUMP_LAYOUT_FIXED_VERSION to it and the script will
# trust dump-layout (skip the heuristic) automatically on >= that version. Empty
# = gate disabled. See https://github.com/zellij-org/zellij/pull/5285
DUMP_LAYOUT_FIXED_VERSION=""
if [ "$no_stealth" -eq 0 ] && [ -n "$DUMP_LAYOUT_FIXED_VERSION" ]; then
  zv="$(zellij --version 2>/dev/null | awk '{print $2}')"
  if [ -n "$zv" ] && \
     [ "$(printf '%s\n%s\n' "$DUMP_LAYOUT_FIXED_VERSION" "$zv" | sort -V | head -n1)" = "$DUMP_LAYOUT_FIXED_VERSION" ]; then
    no_stealth=1
  fi
fi

cfg="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"; proj="$cfg/projects"
tmp="$(mktemp)"; trap 'rm -f "$tmp"' EXIT
if [ -n "$src" ]; then cp "$src" "$tmp"; else zellij action dump-layout > "$tmp"; fi
mkdir -p "$(dirname "$out")"

RESUME_BIN="${CLAUDE_RESUME_BIN:-$(command -v claude-resume 2>/dev/null || echo "$HOME/bin/claude-resume")}"
SUSPEND="$suspend" RUN_ALL="$run_all" NO_STEALTH="$no_stealth" KEEP_SWAP="$keep_swap" SELF="$(basename "$0")" PROJ="$proj" RESUME_BIN="$RESUME_BIN" SESS_DIR="$cfg/sessions" ZJ_SESSION="${ZELLIJ_SESSION_NAME:-}" python3 - "$tmp" > "$out" <<'PY'
import sys, os, re, glob, json, subprocess
dump = open(sys.argv[1]).read().split('\n')
proj = os.environ["PROJ"]; keep_suspend = os.environ["SUSPEND"] == "1"
run_all = os.environ.get("RUN_ALL") == "1"
no_stealth = os.environ.get("NO_STEALTH") == "1"
keep_swap = os.environ.get("KEEP_SWAP") == "1"
resume_bin = os.environ["RESUME_BIN"]
self_name = os.environ.get("SELF", "clauding-snapshot")  # this script's own basename

def encode(c): return re.sub(r'[^A-Za-z0-9]', '-', c)

sess_dir = os.environ.get("SESS_DIR", "")
zj_session = os.environ.get("ZJ_SESSION", "")

# --- Live-session registry (~/.claude/sessions/<pid>.json) ---------------------
# Claude writes one file per running CLI process: {pid, sessionId, cwd, status,
# updatedAt}. This is ground truth for "which session is live in which cwd, right
# now" — far more reliable than transcript mtime. We additionally attribute each
# process to its zellij session by walking the parent chain to `zellij --server
# .../<name>`, so a cwd open in two windows doesn't cross its panes.
def _alive(pid):
    try: os.kill(int(pid), 0); return True
    except Exception: return False
_ppid_c, _cmd_c = {}, {}
def _ppid(pid):
    if pid not in _ppid_c:
        try: _ppid_c[pid] = int(subprocess.check_output(['ps','-o','ppid=','-p',str(pid)]).strip())
        except Exception: _ppid_c[pid] = 0
    return _ppid_c[pid]
def _cmd(pid):
    if pid not in _cmd_c:
        try: _cmd_c[pid] = subprocess.check_output(['ps','-o','command=','-p',str(pid)]).decode('utf-8','replace').strip()
        except Exception: _cmd_c[pid] = ''
    return _cmd_c[pid]
def _zj_of(pid):
    seen = 0
    while pid and pid > 1 and seen < 15:
        c = _cmd(pid)
        if 'zellij' in c and '--server' in c:
            return c.rstrip().split('/')[-1]
        pid = _ppid(pid); seen += 1
    return None

_live, _loaded = {}, {'v': False}
def _load_live():
    if _loaded['v']: return
    _loaded['v'] = True
    if not sess_dir: return
    rows = []
    for f in glob.glob(os.path.join(sess_dir, '*.json')):
        try: d = json.load(open(f))
        except Exception: continue
        pid, sid, cwd = d.get('pid'), d.get('sessionId'), d.get('cwd')
        if not (pid and sid and cwd) or not _alive(pid): continue
        if 'claude' not in _cmd(pid): continue                 # guard against pid reuse
        if zj_session and _zj_of(pid) != zj_session: continue  # scope to current window
        rows.append((cwd, sid, d.get('status') or '', d.get('updatedAt', 0)))
    prio = {'busy': 0, 'waiting': 1, 'idle': 2}
    for cwd in set(r[0] for r in rows):
        items = sorted((r for r in rows if r[0] == cwd),
                       key=lambda r: (prio.get(r[2], 3), -r[3]))
        seen, ids = set(), []
        for _c, sid, _s, _u in items:
            if sid not in seen: seen.add(sid); ids.append(sid)
        _live[cwd] = ids
def live_ids(cwd):
    _load_live(); return _live.get(cwd, [])

# --- Transcript mtime fallback ------------------------------------------------
_pool = {}
def pool(cwd):
    if cwd not in _pool:
        d = os.path.join(proj, encode(cwd))
        fs = glob.glob(os.path.join(d, '*.jsonl')) + glob.glob(os.path.join(d, 'sessions', '*.jsonl'))
        fs.sort(key=os.path.getmtime, reverse=True)
        _pool[cwd] = [os.path.splitext(os.path.basename(f))[0] for f in fs]
    return _pool[cwd]

_returned = {}
def take(cwd):
    ret = _returned.setdefault(cwd, [])
    for sid in live_ids(cwd):     # 1) live session in this window (authoritative)
        if sid not in ret: ret.append(sid); return sid
    for sid in pool(cwd):         # 2) fall back to most-recent transcript (mtime)
        if sid not in ret: ret.append(sid); return sid
    return None

# global cwd for resolving relative pane cwds
gcwd = '/'
for ln in dump:
    m = re.match(r'\s*cwd\s+"([^"]+)"', ln)
    if m: gcwd = m.group(1); break
def absci(c):
    return c if c.startswith('/') else os.path.normpath(os.path.join(gcwd, c))

is_claude = re.compile(r'command="claude"(?!-)')   # exact claude, not claude-resume
cmd_re    = re.compile(r'command="([^"]*)"')
cwd_re    = re.compile(r'cwd="([^"]*)"')

def pane_cwd(ln):
    raw = cwd_re.search(ln); return absci(raw.group(1)) if raw else gcwd

# A pane that runs THIS script (e.g. the floating launcher that happened to be
# running clauding-snapshot when the session was captured). On restore we don't
# want it to re-run the snapshotter — we replace it with a plain shell. Match a
# pane whose command IS the script, or a shell whose args invoke it.
_shells = {'bash', 'sh', 'zsh', 'fish', 'dash', 'ksh'}
def is_self_runner(opener, inner):
    m = cmd_re.search(opener)
    if not m: return False
    base = os.path.basename(m.group(1))
    if self_name and self_name in base: return True
    if base in _shells: return any(self_name in b for b in inner if 'args' in b)
    return False

# Pre-scan per cwd: count claude-bound panes (exact `claude`, or already
# `claude-resume`) vs other command panes. A "stealth" claude pane is one zellij
# mislabeled with a claude-spawned child command (an MCP server, caffeinate, ...).
# We recover it only when its cwd has an unbound live claude session AND it is the
# sole other command pane there — so a real dev-server pane is never clobbered.
claude_cmd_count, other_cmd_count = {}, {}
for ln in dump:
    if 'pane' not in ln or not cmd_re.search(ln): continue
    cwd = pane_cwd(ln)
    if is_claude.search(ln) or 'claude-resume' in ln or resume_bin in ln:
        claude_cmd_count[cwd] = claude_cmd_count.get(cwd, 0) + 1
    else:
        other_cmd_count[cwd] = other_cmd_count.get(cwd, 0) + 1

def is_stealth_claude(cwd):
    # Recover masked claude panes only when the cwd's mystery command panes all fit
    # within its unbound live claude sessions (count(other) <= unbound). If there are
    # more command panes than unbound sessions we can't tell which are claude, so we
    # bail (never clobber a real dev-server pane).
    unbound = len(live_ids(cwd)) - claude_cmd_count.get(cwd, 0)
    return unbound > 0 and other_cmd_count.get(cwd, 0) <= unbound

def gather_block(start):
    depth, j, inner, close = 1, start + 1, [], None
    while j < len(dump) and depth > 0:
        b = dump[j]; depth += b.count('{') - b.count('}')
        if depth > 0: inner.append(b)
        else: close = b
        j += 1
    return inner, close, j

report = []
report_self = 0
out, i = [], 0
while i < len(dump):
    ln = dump[i]
    # Drop swap_tiled_layout / swap_floating_layout blocks. In a *restore* layout
    # they make zellij snap the restored arrangement to a generic swap layout the
    # first time a pane is closed (auto_layout -> relayout_tiled_panes); with no
    # swap layouts, closing a pane just reflows locally and stays put.
    if (not keep_swap) and ln.rstrip().endswith('{') \
       and re.match(r'\s*(swap_tiled_layout|swap_floating_layout)\b', ln):
        _inner, _close, i = gather_block(i)
        continue
    cm = cmd_re.search(ln) if 'pane' in ln else None
    if cm:
        cwd = pane_cwd(ln)
        # Replace a pane that runs this snapshotter with a plain shell: drop the
        # command/args/start_suspended, keep the geometry & other attributes.
        cbase = os.path.basename(cm.group(1))
        if (self_name in cbase) or (cbase in _shells):
            block = ln.rstrip().endswith('{')
            inner, close, j = gather_block(i) if block else ([], None, i + 1)
            if is_self_runner(ln, inner):
                # plain shell, and don't let the launcher grab focus on restore
                opener = re.sub(r'\s+command="[^"]*"', '', ln, count=1)
                opener = re.sub(r'\s+focus=(?:true|false)\b', '', opener)
                out.append(opener)
                if block:
                    out.extend(b for b in inner
                               if 'args' not in b and 'start_suspended' not in b)
                    out.append(close)
                report_self += 1; i = j; continue
        claude_here = bool(is_claude.search(ln))
        is_resume = 'claude-resume' in ln or resume_bin in ln
        stealth = (not no_stealth) and (not claude_here) and (not is_resume) and is_stealth_claude(cwd)
        if claude_here or stealth:
            indent = re.match(r'\s*', ln).group(0)
            opener = cmd_re.sub('command="%s"' % resume_bin, ln, count=1)
            opener = re.sub(r'\s+name="cc:[^"]*"', '', opener)
            sid = take(cwd)
            if claude_here:
                src = 'live' if (sid and sid in live_ids(cwd)) else ('mtime' if sid else 'pick')
            else:
                src = 'stealth' if sid else 'pick'
            report.append((cwd, sid, src))
            arg = f'{indent}    args "--id" "{sid}"' if sid else f'{indent}    args "--pick"'
            if ln.rstrip().endswith('{'):
                inner, close, j = gather_block(i)
                kept = [b for b in inner
                        if 'args' not in b and ('start_suspended' not in b or keep_suspend)]
                out.append(opener); out.append(arg); out.extend(kept); out.append(close)
                i = j; continue
            else:
                out.append(opener.rstrip() + ' {'); out.append(arg); out.append(f'{indent}}}')
                i += 1; continue
        elif run_all and (not is_resume) and ln.rstrip().endswith('{'):
            # genuine non-claude command pane: drop start_suspended so it auto-runs
            inner, close, j = gather_block(i)
            kept = [b for b in inner if 'start_suspended' not in b]
            out.append(ln); out.extend(kept); out.append(close)
            i = j; continue
    out.append(ln); i += 1

hdr = "// generated by clauding-snapshot — launch with: zellij --layout <thisfile>\n"
sys.stdout.write(hdr + '\n'.join(out))
# summary to stderr
sys.stderr.write("clauding-snapshot: rewrote %d claude pane(s)\n" % len(report))
if report_self:
    sys.stderr.write("  + replaced %d clauding-snapshot launcher pane(s) with a plain shell\n" % report_self)
for cwd in sorted(set(c for c, _s, _src in report)):
    items = [(s, src) for c, s, src in report if c == cwd]
    rendered = ", ".join(("%s[%s]" % (s[:8], src) if s else "PICK") for s, src in items)
    sys.stderr.write("  %-45s -> %s\n" % (cwd, rendered))
PY
abs_out="$(cd "$(dirname "$out")" && pwd)/$(basename "$out")"
sess="${ZELLIJ_SESSION_NAME:-}"
echo "clauding-snapshot: wrote $abs_out" >&2
echo "" >&2
echo "To restore, run from OUTSIDE the session (detach first with Ctrl-q):" >&2
if [ -n "$sess" ]; then
  echo "    zellij kill-session \"$sess\" 2>/dev/null; zellij --layout \"$abs_out\"" >&2
else
  echo "    zellij --layout \"$abs_out\"" >&2
fi
